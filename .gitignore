# ============================================================================
# BlackHole Simulation System - Git Ignore
# ----------------------------------------------------------------------------
# This file excludes local environment files, generated outputs, caches,
# compiled artifacts, and operating-system-specific noise from version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Python cache and bytecode
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
__MACOSX/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log

# Keep the logs directory structure, but ignore generated log contents.
logs/*
!logs/.gitkeep

# ---------------------------------------------------------------------------
# Output data
# ---------------------------------------------------------------------------
# Keep the output directory structure, but ignore generated files.
data/output/*
!data/output/.gitkeep

# ---------------------------------------------------------------------------
# C build artifacts
# ---------------------------------------------------------------------------
*.o
*.out
*.exe

# Local compiled binaries present in src/c
src/c/orbit_solver
src/c/gravity_core
src/c/schwarzschild

# ---------------------------------------------------------------------------
# Archives
# ---------------------------------------------------------------------------
*.zip
*.tar
*.gz
